# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=metora_file

# ---- Storage backend: "local" | "minio" ----
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./.data/objects

# ---- MinIO (only used when STORAGE_BACKEND=minio) ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_DEFAULT_BUCKET=metora-file

# ---- Admin UI ----
ADMIN_UI_ENABLED=true
ADMIN_UI_BASIC_AUTH_USERNAME=admin
ADMIN_UI_BASIC_AUTH_PASSWORD=admin123

# ---- Service ----
BASE_URL=http://localhost:8000
# Secret used to sign local download URLs (change in production)
SIGNING_SECRET=change-me-in-production
API_TOKEN_ENV=live
